<UserControl x:Class="A_P_SmartHub.Type_devices_with_graphics.graphicsForDevicesType.LightTemplate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Type_devices_with_graphics.graphicsForDevicesType"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1000">
    <Grid>

        <Border Height="500"  Width="700" Background="#1A2235" CornerRadius="30" BorderThickness="1" BorderBrush="#2A3342" Margin="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.4" Color="Black"/>
            </Border.Effect>

            <Border CornerRadius="30"  HorizontalAlignment="Stretch" Background="#374151">
                <Grid Margin="10" >
                    <TextBlock Text="Light" FontSize="40" FontWeight="Bold" Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Left" FontFamily="Bahnschrift" Margin="0,10,10,0"/>
                    <Button VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,10,10,0" Background="Transparent" Content="X" Click="CloseButton_Click" Foreground="White" FontSize="30" BorderThickness="0" Height="50" />


                    <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="400">

                        <Border>
                            
                        <Path Data="{StaticResource IconLights}" Fill="White" Width="100" Height="100" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                        </Border>


                        <Grid>
                            <TextBlock Text="{Binding ElementName=BrightnessSlider, Path=Value, StringFormat='{}{0:F0}%'}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="20" Foreground="White" Margin="0,0,10,0"/>
                        <Slider  Margin="0,40,0,0" VerticalAlignment="Center"  x:Name="BrightnessSlider" 
                         Minimum="0" 
                          Maximum="100" 
                         Value="{Binding Brightness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                      Foreground="#F59E0B"
                      MouseWheel="BrightnessSlider_MouseWheel"/>
                        </Grid>
                        
                        




                    </StackPanel>
                </Grid>
            </Border>



        </Border>

    </Grid>
</UserControl>
