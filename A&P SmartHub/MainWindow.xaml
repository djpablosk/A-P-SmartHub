<Window x:Class="A_P_SmartHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:A_P_SmartHub"
        xmlns:additional="clr-namespace:A_P_SmartHub.Graphics.Additional"
        xmlns:login="clr-namespace:A_P_SmartHub.Graphics.Login"
        Title="Smart Hub" Height="800" Width="1500"
        WindowStyle="None"
        AllowsTransparency="True"
        xmlns:registration="clr-namespace:A_P_SmartHub.Graphics.MainGrap"
  
        RenderOptions.BitmapScalingMode="LowQuality"
        RenderOptions.EdgeMode="Aliased"
        Background="Black">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>

        </Grid.RowDefinitions>


        <ContentControl Grid.Row="1" Name="UpperBar"/>
        


        <ContentControl Grid.Row="2" x:Name="MainDisplay"/>


       
        


       
           


        

    </Grid>
</Window>