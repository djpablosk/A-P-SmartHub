<Window x:Class="A_P_SmartHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:A_P_SmartHub"
        xmlns:additional="clr-namespace:A_P_SmartHub.Graphics.Additional"
        xmlns:login="clr-namespace:A_P_SmartHub.Graphics.Login"
        Title="Smart Hub" Height="800" Width="1500"
        WindowStyle="None"
        AllowsTransparency="True"
        xmlns:registration="clr-namespace:A_P_SmartHub.Graphics.MainGrap"
        Icon="/Graphics/MainGrap/Login/ChatGPT Image 16. 2. 2026, 20_11_40.png"
        Background="Black">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <additional:CustomUpperBar Grid.Row="0"/>


        <ContentControl Grid.Row="1" x:Name="MainDisplay"/>



        <Grid x:Name="loginBorder"
              HorizontalAlignment="Left"
              Height="466"
              VerticalAlignment="Top"
              Width="497">
            <Grid.Background>
                <ImageBrush ImageSource="/Graphics/Additional/Gemini_Generated_Image_qbiokcqbiokcqbio.png"/>
            </Grid.Background>
        </Grid>


        <Grid x:Name="LoginDarkBlue"
              HorizontalAlignment="Left"
              Height="434"
              Margin="485,0,0,0"
              VerticalAlignment="Center"
              Width="315">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="1"/>
                    <GradientStop Color="#FF6122B1" Offset="0"/>
                    <GradientStop Color="#FE050109" Offset="0.948"/>
                    <GradientStop Color="#FE142898" Offset="0.722"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid x:Name="Login_Label" Margin="0,0,0,361"/>
            <Label x:Name="LoginLabel" Content="Registration&#xD;&#xA;" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.608,-0.948" Foreground="White" FontSize="24" FontWeight="Bold"/>
            <Border BorderBrush="Black" BorderThickness="1"  CornerRadius="10" HorizontalAlignment="Center" Height="40" Margin="0,73,0,0" VerticalAlignment="Top" Width="189">
                <TextBox x:Name="usernamebox_Copy1" TextWrapping="Wrap" Background="Transparent" BorderThickness="0" Text="Username..." Foreground="#FFFDF0F0" Padding="0,0,4,0" HorizontalScrollBarVisibility="Auto" UseLayoutRounding="False" HorizontalContentAlignment="Right" FontSize="25" HorizontalAlignment="Left" Margin="9,4,0,4" Width="159" GotFocus="usernamebox_Copy1_GotFocus_1"/>
            </Border>
            <Border UseLayoutRounding="False" BorderBrush="Transparent" BorderThickness="1" Margin="30,78,257,321">
                <Border.Background>
                    <!-- Replaced missing /user.png with an existing packaged resource -->
                    <ImageBrush ImageSource="/Graphics/MainGrap/Login/1368afba-9254-4f91-bd56-95b1d642cb0d.png" Stretch="UniformToFill" TileMode="None"/>

                </Border.Background>
            </Border>
            <Border BorderBrush="Black" CornerRadius="10
                    " BorderThickness="1" Margin="63,138,63,256" Width="189" Height="40">
                <PasswordBox x:Name="confirmpassbox" BorderThickness="0" FocusVisualStyle="{x:Null}" Background="Transparent" Foreground="White" BorderBrush="Transparent"  Margin="0,5,0,5" SelectionBrush="{x:Null}" FontSize="15" HorizontalAlignment="Center" Width="168" />
            </Border>
            <Border BorderBrush="Black" CornerRadius="10 " BorderThickness="1" Margin="63,197,63,197" Width="189" Height="40">
                <PasswordBox  BorderThickness="0" Background="Transparent" Foreground="White" BorderBrush="Transparent" TextBlock.FontSize="15" SelectionBrush="{x:Null}" HorizontalAlignment="Center" Width="170" Margin="0,5,0,5"/>
            </Border>
            <Border BorderBrush="Transparent" BorderThickness="1" Margin="24,140,263,258">
                <Border.Background>
                    <!-- Replaced missing /fingerprint-scan.png with an existing packaged resource -->
                    <ImageBrush ImageSource="/Graphics/MainGrap/Registration/45a591d1-d0fb-4810-8ea6-112199adddb2.png" Stretch="UniformToFill" TileMode="None"/>

                </Border.Background>
            </Border>
            <Border BorderBrush="Transparent" BorderThickness="1" Margin="24,197,263,202">
                <Border.Background>
                    <!-- Replaced missing /fingerprint-scan.png with an existing packaged resource -->
                    <ImageBrush ImageSource="/Graphics/MainGrap/Registration/45a591d1-d0fb-4810-8ea6-112199adddb2.png" Stretch="UniformToFill" TileMode="None"/>

                </Border.Background>
            </Border>


        </Grid>

    </Grid>
</Window>