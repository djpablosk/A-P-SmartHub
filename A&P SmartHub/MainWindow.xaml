<Window x:Class="A_P_SmartHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:A_P_SmartHub"
        xmlns:additional="clr-namespace:A_P_SmartHub.Graphics.Additional"
        xmlns:login="clr-namespace:A_P_SmartHub.Graphics.Login"
        Title="Smart Hub" Height="1000" Width="1500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Black">

    <Grid Background="Black">
        <Grid.RowDefinitions>
                 <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

       <additional:CustomUpperBar Grid.Row="0"/>
        <login:Login Grid.Row="1"/>
    



    </Grid>
</Window>