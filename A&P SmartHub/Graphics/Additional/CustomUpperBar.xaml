<UserControl x:Class="A_P_SmartHub.Graphics.Additional.CustomUpperBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="1500">
    <Grid>
        <Rectangle Fill="#333333"/>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Stretch" Orientation="Horizontal" >

            <Button Content="—" HorizontalAlignment="Left" Height="30"  VerticalAlignment="Center" Width="46" Background="{x:Null}" BorderBrush="{x:Null}" FontSize="24" FontFamily="Calibri" Click="MinimizeButton_Click"/>
            <Button Content="▢" HorizontalAlignment="Left" Height="30"  VerticalAlignment="Center" Width="46" Background="{x:Null}" BorderBrush="{x:Null}" FontSize="24" FontFamily="Calibri" Click="MaxRestoreButton_Click"/>
            <Button Content="✕" HorizontalAlignment="Left" Height="30"  VerticalAlignment="Center" Width="46" Background="{x:Null}" BorderBrush="{x:Null}" FontSize="24" FontFamily="Calibri" Click="CloseButton_Click"/>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Width="180" Orientation="Horizontal" >
            <Image HorizontalAlignment="Left" Height="62" Margin="-15" Width="76" Source="/Graphics/Additional/A&amp;P SmartHub Image Cut.png"/>
            <TextBlock HorizontalAlignment="Center" Width="130" Text="A&amp;P Smarthub" VerticalAlignment="Center" FontFamily="Impact" FontSize="22"  />
        </StackPanel>

    </Grid>
</UserControl>
