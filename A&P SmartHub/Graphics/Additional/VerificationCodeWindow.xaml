<UserControl x:Class="A_P_SmartHub.Graphics.Additional.VerificationCodeWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500">
    <Viewbox Stretch="UniformToFill">

        <Grid Height="900" Width="1500">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF311060" Offset="0"/>
                <GradientStop Color="#FF1E093D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False">

            <Ellipse Width="800" Height="800" Canvas.Left="-200" Canvas.Top="-150" Opacity="0.5">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF00F2FF" Offset="0"/>
                        <GradientStop Color="#0000F2FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="700" Height="700" Canvas.Right="50" Canvas.Top="-100" Opacity="0.4">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFF00D4" Offset="0"/>
                        <GradientStop Color="#00FF00D4" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="130"/>
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="600" Height="600" Canvas.Right="-150" Canvas.Bottom="-100" Opacity="0.3">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFF9500" Offset="0"/>
                        <GradientStop Color="#00FF9500" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>

        </Canvas>

        <Rectangle IsHitTestVisible="False" Opacity="0.05">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="0.7"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="25">
        <Grid.ColumnDefinitions>
            
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="680"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

            <Border Grid.Row="1" Grid.Column="1" CornerRadius="30" BorderThickness="1.2" Background="#22FFFFFF" BorderBrush="#44FFFFFF"  HorizontalAlignment="Stretch" >

            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.2" ShadowDepth="0"/>
            </Border.Effect>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Margin="0,40" VerticalAlignment="Center"  HorizontalAlignment="Center"  Text="Verification code" FontFamily="Impact" FontSize="72" Foreground="White"  />
           <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"  Margin="100,0" TextWrapping="Wrap" Text="Enter the code sent to your email:" Width="500" FontSize="36" FontFamily="Impact" Foreground="White"/>
            <Border Background="Transparent" Margin="0,20" Width="500" CornerRadius="20" BorderThickness="1" HorizontalAlignment="Center" BorderBrush="White">
                <TextBox x:Name="VerifCodeInput" FontSize="48" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"      BorderThickness="0"  Height="64" />
            </Border>
            <Border Width="500" VerticalAlignment="Bottom" Margin="0,90" Background="#9D44FF"  Height="64" BorderBrush="White" BorderThickness="1" CornerRadius="20">
                <Button  BorderThickness="0" Content="Register" HorizontalAlignment="Stretch"  Background="Transparent" FontSize="31" FontFamily="Impact" FontWeight="Bold"   BorderBrush="{x:Null}" Foreground="White" Width="500" Click="Button_Click"/>
            </Border>


        </StackPanel>
            

        </Grid>
    </Grid>
    </Viewbox>
</UserControl>
