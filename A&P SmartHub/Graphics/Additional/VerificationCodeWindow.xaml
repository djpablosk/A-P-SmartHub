<UserControl x:Class="A_P_SmartHub.Graphics.Additional.VerificationCodeWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4A2691" Offset="0.0"/>
                <GradientStop Color="#6F2DA8" Offset="1.9"/>
                <GradientStop Color="#B21F3C" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="680"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

            <Border Grid.Row="1" Grid.Column="1" CornerRadius="30" BorderThickness="1.2" Background="#22FFFFFF" BorderBrush="#44FFFFFF"  HorizontalAlignment="Stretch" >

            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.2" ShadowDepth="0"/>
            </Border.Effect>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Margin="0,40" VerticalAlignment="Center"  HorizontalAlignment="Center"  Text="Verification code" FontFamily="Impact" FontSize="72" Foreground="White"  />
           <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"  Margin="100,0" TextWrapping="Wrap" Text="Enter the code sent to your email:" Width="500" FontSize="36" FontFamily="Impact" Foreground="White"/>
            <Border Background="Transparent" Margin="0,20" Width="500" CornerRadius="20" BorderThickness="1" HorizontalAlignment="Center" BorderBrush="White">
                <TextBox FontSize="48" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"      BorderThickness="0"  Height="64" />
            </Border>
            <Border Width="500" VerticalAlignment="Bottom" Margin="0,90" Background="#9D44FF"  Height="64" BorderBrush="White" BorderThickness="1" CornerRadius="20">
                <Button  BorderThickness="0" Content="Register" HorizontalAlignment="Stretch"  Background="Transparent" FontSize="31" FontFamily="Impact" FontWeight="Bold"   BorderBrush="{x:Null}" Foreground="White" Width="500" Click="Button_Click"/>
            </Border>


        </StackPanel>
            

    </Grid>
</UserControl>
