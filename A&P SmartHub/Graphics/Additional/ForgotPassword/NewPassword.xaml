<UserControl x:Class="A_P_SmartHub.Graphics.Additional.ForgotPassword.NewPassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional.ForgotPassword"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid >
        <Border Background="#374151" CornerRadius="30" Padding="20" Width="500" Height="250" HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel>
                <TextBlock Text="Create New Password" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBox Width="300" Height="30" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                <TextBox Width="300" Height="30" Margin="0,20,0,0" HorizontalAlignment="Center"/>

                <Border Width="300" Height="35" Margin="0,20" BorderThickness="1.5" Background="#2A3342" CornerRadius="20" >
                    <Border.CacheMode>
                        <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="True" />
                    </Border.CacheMode>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF1493" Offset="0.0" />
                            <GradientStop Color="#FFC400" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>

                    <Button Cursor="Hand" Background="Transparent" BorderThickness="0" FocusVisualStyle="{x:Null}" Click="ResetPassword_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </ControlTemplate>
                        </Button.Template>
                        <Border CacheMode="BitmapCache" Background="#22FFFFFF" CornerRadius="20">
                            <TextBlock Text="Reset Password" FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#E0E6ED" FontFamily="Bahnschrift" />
                        </Border>
                    </Button>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2" />
                                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2" />
                                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
