<UserControl x:Class="A_P_SmartHub.Graphics.Additional.HomeSetup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500">
    
    <Grid Background="#0E1620">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="*"/>
        
        </Grid.ColumnDefinitions>
        <Border Margin="20" Background="#374151" CornerRadius="30">
            <StackPanel Margin="10" >
                <TextBlock Text="Home Setup" FontFamily="Bahnschrift" FontSize="40" HorizontalAlignment="Center" FontWeight="Bold" Margin="10"/>
                <TextBlock Text="Enter your home name below:" FontFamily="Bahnschrift" FontSize="20" HorizontalAlignment="Center" Margin="10"/>
                <TextBox Margin="10" BorderBrush="Black" Height="40" Background="Transparent" FontSize="30" FontFamily="Bahnschrift" />
                <TextBlock Text="Enter your name below:" FontFamily="Bahnschrift" FontSize="20" HorizontalAlignment="Center" Margin="10"/>
                <TextBox Margin="10" BorderBrush="Black" Height="40" Background="Transparent" FontSize="30" FontFamily="Bahnschrift" />
                <TextBlock Text="Enter your city below:" FontFamily="Bahnschrift" FontSize="20" HorizontalAlignment="Center" Margin="10"/>
                <TextBox Margin="10" BorderBrush="Black" Height="40" Background="Transparent" FontSize="30" FontFamily="Bahnschrift" />
                

            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/> 
            </Grid.ColumnDefinitions>
            
            
        </Grid>
    </Grid>
</UserControl>
