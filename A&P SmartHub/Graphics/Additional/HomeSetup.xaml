<UserControl x:Class="A_P_SmartHub.Graphics.Additional.HomeSetup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500">
    
    <Grid Background="#0E1620">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="*"/>
        
        </Grid.ColumnDefinitions>
        <Border Margin="20" Background="#374151" CornerRadius="30">
            <StackPanel Margin="10" >
                <TextBlock Foreground="#E0E6ED" Text="Home Setup" FontFamily="Bahnschrift" FontSize="40" HorizontalAlignment="Center" FontWeight="Bold" Margin="10"/>
                <TextBlock Foreground="#E0E6ED" Text="Enter your home name below:" FontFamily="Bahnschrift" FontSize="20" HorizontalAlignment="Center" Margin="10"/>
                <Border CornerRadius="20" Height="60" Margin="10" BorderThickness="1" BorderBrush="White">
                    
                <TextBox  BorderThickness="0" BorderBrush="Black" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="Transparent" FontSize="50" FontFamily="Bahnschrift" />
                </Border>
                <TextBlock Foreground="#E0E6ED" Text="Enter your name below:" FontFamily="Bahnschrift" FontSize="20" HorizontalAlignment="Center" Margin="10"/>
                <Border CornerRadius="20" Height="60" Margin="10" BorderThickness="1" BorderBrush="White">
                <TextBox  BorderThickness="0" BorderBrush="Black" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="Transparent" FontSize="50" FontFamily="Bahnschrift" />
                </Border>
                <TextBlock Foreground="#E0E6ED" Text="Enter your city below:" FontFamily="Bahnschrift" FontSize="20" HorizontalAlignment="Center" Margin="10"/>
                <Border CornerRadius="20" Height="60" Margin="10" BorderThickness="1" BorderBrush="White">
                <TextBox FontSize="50"  BorderThickness="0" BorderBrush="Black" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="Transparent"  FontFamily="Bahnschrift" />
                </Border>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/> 
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Margin="20" Background="#374151" CornerRadius="30">
                <StackPanel>
                    <TextBlock Text="Add Device" VerticalAlignment="Top" Height="50" FontSize="40" FontFamily="Bahnschrift" HorizontalAlignment="Left" Foreground="#E0E6ED" Margin="10"/>
                    
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Margin="20" Background="#374151" CornerRadius="30">
                <StackPanel>
                    
                </StackPanel>
            </Border>
            
        </Grid>
    </Grid>
</UserControl>
