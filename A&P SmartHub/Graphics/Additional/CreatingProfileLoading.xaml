<UserControl x:Class="A_P_SmartHub.Graphics.Additional.CreatingProfileLoading"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500">
    <Grid Background="#101725">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <ProgressBar Width="400" Height="30" IsIndeterminate="True" Foreground="#4F46E5" Background="#22FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" Margin="0,0,0,20"/>
            <TextBlock x:Name="TextLoading" Text="Creating Profile..." FontSize="34" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" FontFamily="Bahnschrift"/>
        </StackPanel>    
    </Grid>
</UserControl>
