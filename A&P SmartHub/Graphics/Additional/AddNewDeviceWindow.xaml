<Window x:Class="A_P_SmartHub.Graphics.Additional.AddNewDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Additional"
        mc:Ignorable="d"
        Title="AddNewDeviceWindow" Height="700" Width="1000">
    <Grid Background="#0E1620">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="1" Grid.Row="1" Background="#374151" CornerRadius="30">
            <StackPanel Margin="5">
            <TextBlock Text="Add New Device" FontSize="40" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Bahnschrift" Margin="0,20,0,0"/>
                <TextBlock Text="Device Name" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" FontFamily="Bahnschrift" Margin="10,20,0,5"/>
                <Border Margin="10" Height="50"  CornerRadius="20" BorderThickness="1" BorderBrush="White">
                     <TextBox x:Name="DeviceNameBox" FontSize="40" FontFamily="Bahnschrift"   HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0" VerticalAlignment="Stretch" TextChanged="DeviceName_TextChanged" />
                </Border>
                <TextBlock Text="IP Address" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" FontFamily="Bahnschrift" Margin="10,20,0,5"/>
                <Border Margin="10" Height="50"  CornerRadius="20" BorderThickness="1" BorderBrush="White">
                    <TextBox x:Name="DeviceIPAddressBox" FontSize="40" FontFamily="Bahnschrift"   HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0" VerticalAlignment="Stretch" />
                </Border>
                    <TextBlock Text="Select your device type" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" FontFamily="Bahnschrift" Margin="10,20,0,5"/>
                <ComboBox Background="LightGray" Margin="10" x:Name="deviceType">
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="Toggle" />
                    <ComboBoxItem Content="Climate"/>
                    <ComboBoxItem Content="Cover"/>
                    <ComboBoxItem Content="Media"/>
                    <ComboBoxItem Content="ReadOnly"/>

                </ComboBox>
                
                <Border Margin="10" Height="50"  CornerRadius="20" BorderThickness="1" Background="#22FFFFFF" BorderBrush="White">
                    <Button Click="Button_Click" Content="Add Device" FontSize="25" VerticalAlignment="Stretch"  Foreground="White" HorizontalAlignment="Stretch" FontFamily="Bahnschrift"  Background="Transparent" BorderThickness="0" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
