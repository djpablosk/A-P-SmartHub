<UserControl x:Class="A_P_SmartHub.Graphics.MainGrap.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.MainGrap"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4A2691" Offset="0.0"/>
                <GradientStop Color="#6F2DA8" Offset="0.5"/>
                <GradientStop Color="#B21F3C" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="900" />
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>


            <StackPanel Grid.Row="1" Grid.Column="1" Background="Transparent" >
                <TextBlock Margin="0,40" Height="100" HorizontalAlignment="Center" Width="400" Text="Registration" FontFamily="Impact" FontSize="72" Foreground="White"  />
                <Border Margin="0,70" Width="500" CornerRadius="20" BorderThickness="1" HorizontalAlignment="Center" BorderBrush="White">
                    <TextBox HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"      BorderThickness="0"  Height="64" />
                </Border>
                <Border Width="500" CornerRadius="20" BorderBrush="White" BorderThickness="1" HorizontalAlignment="Center" Height="64">
                    <PasswordBox Background="Transparent" BorderThickness="0" FontFamily="Impact"/>
                </Border>
                <Border Margin="0,-400" Height="700" Width="700" HorizontalAlignment="Right" VerticalAlignment="Center"  >
                    <Image HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  />
                </Border>
            </StackPanel> 
        <Border Grid.Column="1" Width="700" Grid.Row="1" CornerRadius="30" Background="White" Opacity="0.15" BorderThickness="2" Margin="30" >
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                    <GradientStop Color="#33FFFFFF" Offset="1"/>
                </LinearGradientBrush>
              
            </Border.BorderBrush>
        </Border>
    </Grid>
</UserControl>
