<UserControl x:Class="A_P_SmartHub.Graphics.MainGrap.Dashboard.MainDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.MainGrap.Dashboard"
             mc:Ignorable="d"
              RenderOptions.BitmapScalingMode="LowQuality"
              RenderOptions.EdgeMode="Aliased"
             d:DesignHeight="900" d:DesignWidth="1500">
    <Viewbox Stretch="UniformToFill">

        <Grid Height="900" Width="1500">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF311060" Offset="0"/>
                    <GradientStop Color="#FF1E093D" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>



            <Canvas IsHitTestVisible="False">

                <Ellipse Width="800" Height="800" Canvas.Left="-89" Canvas.Top="75" Opacity="0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF00F2FF" Offset="0"/>
                            <GradientStop Color="#0000F2FF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="150"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="700" Height="700" Canvas.Right="50" Canvas.Top="-100" Opacity="0.4">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFF00D4" Offset="0"/>
                            <GradientStop Color="#00FF00D4" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="130"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="600" Height="600" Canvas.Right="-150" Canvas.Bottom="-100" Opacity="0.3" Canvas.Left="1038" Canvas.Top="10">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFF9500" Offset="0"/>
                            <GradientStop Color="#00FF9500" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="150"/>
                    </Ellipse.Effect>
                </Ellipse>

            </Canvas>

            <Rectangle IsHitTestVisible="False" Opacity="0.05">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.5,0">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.7"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border Background="#22808080" Margin="0" CornerRadius="30">
                <StackPanel Orientation="Horizontal" >
                    <TextBlock Text="Dashboard" FontSize="46" FontWeight="Bold" Foreground="White" Margin="20" FontFamily="Impact"/>
                    <TextBlock Text="Overview of your smart home" FontSize="19" Foreground="White" Margin="-210,90,0,0"/>
                    <TextBlock Text="Welcome to AP SmartHub" FontSize="30" FontFamily="Impact" Foreground="White" Margin="850,50,0,0"/>
                </StackPanel>
            </Border>


            <Grid Name="MainDivision" Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="600"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="100"/>

                </Grid.RowDefinitions>
                    <Grid Name="HelooSide"  >
                    <Grid.ColumnDefinitions>
                        
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <Border Margin="5" Background="#22FFFFFF" CornerRadius="30">
                        <StackPanel>
                            <TextBox Background="Transparent" Text="Welcome back, User!" FontSize="50" FontWeight="Bold" Foreground="White" Margin="20" FontFamily="Impact"/>
                            <TextBox Background="Transparent" Text="24 devices are online!" FontSize="19" Foreground="White" Margin="20,0,0,0"/>


                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Margin="5" CornerRadius="30" Grid.Column="1" Background="#1AFFFFFF">
                            <Rectangle Fill="Orange"/>  
                        </Border>
                        <Border Margin="5" Grid.Row="1" Background="#1AFFFFFF" CornerRadius="30">
                            <StackPanel Orientation="Horizontal">
                            <TextBox Text="45%" Foreground="White" FontSize="40" VerticalAlignment="Bottom" FontFamily="Impact" Background="Transparent"  Height="50" Width="100" Margin="0,0,0,0"/>
                            <TextBlock Foreground="White" Text="Humidity" FontSize="40" VerticalAlignment="Bottom" FontFamily="Impact" Background="Transparent"  Height="50" Width="220" Margin="-150,0,0,0"/>
                                
                            </StackPanel>

                        </Border>
                        <Border Margin="5" Background="#1AFFFFFF" CornerRadius="30">
                            <StackPanel Orientation="Horizontal">
                                <Border VerticalAlignment="Top" Width="90" Height="70" CornerRadius="8">
                                   
                                </Border>

                                <TextBlock Foreground="White" Text="Temperature" FontSize="40" VerticalAlignment="Bottom" FontFamily="Impact" Background="Transparent"  Height="50" Width="220" Margin="-85,0,0,0"/>
                                <TextBox  Text="22°C" Foreground="White" FontSize="40" VerticalAlignment="Bottom" FontFamily="Impact" Background="Transparent"  Height="50" Width="100" Margin="70,0,0,0"/>


                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Background="#1AFFFFFF" CornerRadius="30" Margin="5">
                            <Rectangle Fill="White"/>
                        </Border>
                        <Border Grid.Column="1" Grid.Row="1" Margin="5" CornerRadius="30" Background="#1AFFFFFF">
                            <Rectangle Fill="Blue" />
                        </Border>
                        <Border Grid.Column="1" Grid.Row="2" Margin="5" CornerRadius="30" Background="#1AFFFFFF">
                            <Rectangle Fill="Gray"/>
                        </Border>
                        
                    </Grid>
                    </Grid>

                <Border Margin="5" CornerRadius="30" Background="#22FFFFFF" Name="DevicesSide" Grid.Column="1">
                    
                </Border>
                
                
            </Grid>


        
            
            
            
            
            
            
            
            
            
            
            
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
        </Grid>


    </Viewbox>
</UserControl>
