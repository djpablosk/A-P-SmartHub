<UserControl x:Class="A_P_SmartHub.Graphics.MainGrap.Dashboard.MainDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.MainGrap.Dashboard"
             mc:Ignorable="d"
              RenderOptions.BitmapScalingMode="LowQuality"
              RenderOptions.EdgeMode="Aliased"
             d:DesignHeight="900" d:DesignWidth="1500">
    
        <Grid  Background="#101725">
        <Grid.RowDefinitions>
           
            <RowDefinition Height="*"/>
           
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>
       

        <ContentControl Grid.Row="0" x:Name="MainDisplay"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Background="Transparent" Click="HomePage_Click" >
                <Path HorizontalAlignment="Center"  VerticalAlignment="Center" 
              Width="40" Height="40" Stretch="Uniform" 
              Fill="#A9ACBB" 
              Data="M12 5.69l5 4.5V18h-2v-6H9v6H7v-7.81l5-4.5M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
            </Button>

            <Button Grid.Column="1" Background="Transparent" Click="AllDevices_Click">
                
                <Path HorizontalAlignment="Center" VerticalAlignment="Center" 
              Width="40" Height="40" Stretch="Uniform" 
              Fill="#A9ACBB" 
              Data="M4,6H22V20H24V22H0V20H2V6C2,4.89 2.89,4 4,4H20C21.1,4 22,4.89 22,6V8H20V6H4V18H10V20H4Z M20,10H16C15.45,10 15,10.45 15,11V21C15,21.55 15.45,22 16,22H20C20.55,22 21,21.55 21,21V11C21,10.45 20.55,10 20,10Z M19,19H17V12H19Z"/>
            </Button>
            <Button Click="Menu_Click" Grid.Column="2" Background="Transparent">
                
                <Path HorizontalAlignment="Center" VerticalAlignment="Center" 
              Width="40" Height="40" Stretch="Uniform" 
              Fill="#A9ACBB" 
              Data="M3,18H21V16H3V18ZM3,13H21V11H3V13ZM3,6V8H21V6H3Z"/>
            </Button>
        </Grid>
            
            
    </Grid>
</UserControl>
