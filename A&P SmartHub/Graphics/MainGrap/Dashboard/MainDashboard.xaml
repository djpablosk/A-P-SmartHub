<UserControl x:Class="A_P_SmartHub.Graphics.MainGrap.Dashboard.MainDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.MainGrap.Dashboard"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500">
    <Viewbox Stretch="UniformToFill">
        
        <Grid Height="900" Width="1500">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF311060" Offset="0"/>
                <GradientStop Color="#FF1E093D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Canvas IsHitTestVisible="False">

            <Ellipse Width="800" Height="800" Canvas.Left="-200" Canvas.Top="-150" Opacity="0.5">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF00F2FF" Offset="0"/>
                        <GradientStop Color="#0000F2FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="700" Height="700" Canvas.Right="50" Canvas.Top="-100" Opacity="0.4">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFF00D4" Offset="0"/>
                        <GradientStop Color="#00FF00D4" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="130"/>
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="600" Height="600" Canvas.Right="-150" Canvas.Bottom="-100" Opacity="0.3">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFF9500" Offset="0"/>
                        <GradientStop Color="#00FF9500" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>

        </Canvas>

        <Rectangle IsHitTestVisible="False" Opacity="0.05">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="0.7"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>


        <Rectangle Grid.Row="0" Fill="White" />
    </Grid>
    
    </Viewbox>
</UserControl>
