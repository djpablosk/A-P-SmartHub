<UserControl x:Class="A_P_SmartHub.Graphics.Login.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Login"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1500">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.Row="1" Fill="black"/>
        <Rectangle Grid.Row="0" Fill="black"/>

        <Border Grid.Row="1" CornerRadius="30" BorderThickness="1.2" Background="#1AFFFFFF" Margin="70" >
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="1" Margin="80" >
        <TextBlock HorizontalAlignment="Left" Margin="0,10,10,60" Height="88" TextWrapping="Wrap" Text="Login:" VerticalAlignment="Top" Width="175" Grid.Row="1" FontSize="72" FontFamily="Impact" Foreground="White"/>

        <TextBlock Margin="0,10,0,30" HorizontalAlignment="Left" Height="42"  TextWrapping="Wrap" Text="Username:" VerticalAlignment="Top" Width="163" Grid.Row="1" FontSize="36" FontFamily="Impact" Foreground="White"/>
        <TextBox HorizontalAlignment="Center" Height="64"  TextWrapping="Wrap" VerticalAlignment="Top" Width="482" Grid.Row="1" FontSize="48" Background="{x:Null}"/>
       
         <TextBlock Margin="0,10,0,30" HorizontalAlignment="Left" Height="42"  TextWrapping="Wrap" Text="Password:" VerticalAlignment="Top" Width="163" Grid.Row="1" FontSize="36" FontFamily="Impact" Foreground="White"/>
                <Border CornerRadius="20" Width="482" Height="64" BorderThickness="1" BorderBrush="#33FFFF">
                    <PasswordBox BorderThickness="0"  HorizontalAlignment="Stretch"   VerticalAlignment="Stretch"  Background="{x:Null}" FontSize="48"/>
                    
                </Border>
        <Button Margin="0,40,0,30" Content="Login" HorizontalAlignment="Right" Height="40"  VerticalAlignment="Top" Width="146" Grid.Row="1" Background="#FF0F2031" FontSize="31" FontFamily="Impact" FontWeight="Bold" BorderBrush="{x:Null}"/>
        </StackPanel>
        </Border>




    </Grid>
</UserControl>
