<UserControl x:Class="A_P_SmartHub.Graphics.Login.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Login"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1500">

    <Viewbox Stretch="UniformToFill">
        <Grid x:Name="MainRoot" Background="#101725" Height="900" Width="1500">

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="LoginFlowStates">
                    <VisualState x:Name="NormalState" />

                    <VisualState x:Name="LoggingInState">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="LoginForm" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4" />
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LoginForm" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.4" Value="{x:Static Visibility.Collapsed}"/>
                            </ObjectAnimationUsingKeyFrames>

                            <DoubleAnimation Storyboard.TargetName="LogoTranslate" Storyboard.TargetProperty="X" To="-375" Duration="0:0:0.7">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>

                            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX" To="0.6" Duration="0:0:0.7"/>
                            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY" To="0.6" Duration="0:0:0.7"/>

                            <DoubleAnimation Storyboard.TargetName="LoadingArea" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.6" Duration="0:0:0.4" />
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource GradientHoverPanel}" x:Name="LoginForm" Grid.Column="0" Width="680" Height="700" CornerRadius="30"  Background="#374151" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="44,0,0,0" Width="509" >

                    <TextBlock HorizontalAlignment="Left" Margin="0,10,10,60" Height="88" TextWrapping="Wrap" Text="Login:" VerticalAlignment="Top" Width="185" FontSize="72" FontFamily="Bahnschrift" Foreground="#E0E6ED"/>

                    <TextBlock Margin="10,10,0,30" HorizontalAlignment="Left" Height="42" TextWrapping="Wrap" Text="Email:" VerticalAlignment="Top" Width="163" FontSize="36" FontFamily="Bahnschrift" Foreground="#E0E6ED"/>
                    <Border Margin="10,0" BorderBrush="White" CornerRadius="20" HorizontalAlignment="Left" Height="64" Width="482" BorderThickness="1">
                        <TextBox x:Name="LoginMail" BorderThickness="0" TextWrapping="Wrap" VerticalAlignment="Center" Grid.Row="1" FontSize="40" Background="{x:Null}" Height="62" Foreground="White" CaretBrush="White"/>
                    </Border>

                    <TextBlock Margin="10,10,0,30" HorizontalAlignment="Left" Height="42" TextWrapping="Wrap" Text="Password:" VerticalAlignment="Top" Width="163" FontSize="36" FontFamily="Bahnschrift" Foreground="#E0E6ED"/>
                    <Border CornerRadius="20" Width="482" Height="64" BorderThickness="1" BorderBrush="White">
                        <PasswordBox x:Name="LoginPasword" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="{x:Null}" FontSize="48" Foreground="White" CaretBrush="White"/>
                    </Border>

                    <Border HorizontalAlignment="Right" Width="160" >
                        <Button Cursor="Hand" BorderThickness="0" Background="Transparent" Content="Forgot password" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5" Padding="8,4" FontFamily="Bahnschrift" FontSize="19" Foreground="#E0E6ED" Click="ForgotPassword_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.CacheMode>
                                <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="True" />
                            </Button.CacheMode>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.2" />
                                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2" />
                                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>

                    <Border  VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Width="482" Height="64" Margin="0,20" BorderThickness="1.5" Background="#2A3342" CornerRadius="20" >
                        <Border.CacheMode>
                            <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="True" />
                        </Border.CacheMode>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF1493" Offset="0.0" />
                                <GradientStop Color="#FFC400" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
 
                        <Button Cursor="Hand" Height="55" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Stretch" BorderThickness="0" FocusVisualStyle="{x:Null}" Click="Button_Click_2" >
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Login" FontSize="45" VerticalAlignment="Stretch" HorizontalAlignment="Center" Foreground="#E0E6ED" FontFamily="Bahnschrift" />

                        </Button>

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <Button Cursor="Hand" BorderThickness="0" Background="Transparent" Content="Create new account" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0" Padding="8,4" FontFamily="Bahnschrift" FontSize="19" Foreground="#E0E6ED" Click="Button_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.CacheMode>
                            <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="True" />
                        </Button.CacheMode>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2" />
                                                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="670" Height="800">

                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1" />
                        <TranslateTransform x:Name="LogoTranslate" X="0" Y="0" />
                    </TransformGroup>
                </Grid.RenderTransform>
                <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>

                <Image HorizontalAlignment="Center" VerticalAlignment="Top" Height="688" Width="670" Source="/Graphics/MainGrap/Login/Picture Login.png"/>

                <StackPanel x:Name="LoadingArea" Opacity="0" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="120" 
                                 Height="4" 
                                 Foreground="#53FFDC" 
                                 Background="#22FFFFFF" 
                                 BorderThickness="0"/>
                    <TextBlock Text="Logging in..." 
                               Foreground="#53FFDC" 
                               HorizontalAlignment="Center" 
                               Margin="0,15,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Viewbox>
</UserControl>