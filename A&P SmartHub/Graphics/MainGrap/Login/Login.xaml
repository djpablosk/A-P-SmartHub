<UserControl x:Class="A_P_SmartHub.Graphics.Login.Login"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:A_P_SmartHub.Graphics.Login"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1500">

    
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF311060" Offset="0"/>
                    <GradientStop Color="#FF1E093D" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

            <Canvas IsHitTestVisible="False">

                <Ellipse Width="800" Height="800" Canvas.Left="-200" Canvas.Top="-150" Opacity="0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF00F2FF" Offset="0"/>
                            <GradientStop Color="#0000F2FF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="150"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="700" Height="700" Canvas.Right="50" Canvas.Top="-100" Opacity="0.4">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFF00D4" Offset="0"/>
                            <GradientStop Color="#00FF00D4" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="130"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="600" Height="600" Canvas.Right="-150" Canvas.Bottom="-100" Opacity="0.3">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFF9500" Offset="0"/>
                            <GradientStop Color="#00FF9500" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="150"/>
                    </Ellipse.Effect>
                </Ellipse>

            </Canvas>

            <Rectangle IsHitTestVisible="False" Opacity="0.05">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.5,0">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.7"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

        <Border Width="680" CornerRadius="30" BorderThickness="1.2" Background="#22FFFFFF" BorderBrush="#44FFFFFF" HorizontalAlignment="Left" Margin="70,70,0,70" >
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.2" ShadowDepth="0"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="80" >

                <TextBlock HorizontalAlignment="Left" Margin="0,10,10,60" Height="88" TextWrapping="Wrap" Text="Login:" VerticalAlignment="Top" Width="175" FontSize="72" FontFamily="Impact" Foreground="White"/>

                <TextBlock Margin="0,10,0,30" HorizontalAlignment="Left" Height="42"  TextWrapping="Wrap" Text="Email:" VerticalAlignment="Top" Width="163" FontSize="36" FontFamily="Impact" Foreground="White"/>
                <Border BorderBrush="White" CornerRadius="20" HorizontalAlignment="Left" Height="64" Width="482" BorderThickness="1">
                    <TextBox  BorderThickness="0" HorizontalAlignment="Stretch"  TextWrapping="Wrap" VerticalAlignment="Stretch"  FontSize="48" Background="{x:Null}"/>

                </Border>

                <TextBlock Margin="0,10,0,30" HorizontalAlignment="Left" Height="42"  TextWrapping="Wrap" Text="Password:" VerticalAlignment="Top" Width="163" FontSize="36" FontFamily="Impact" Foreground="White"/>
                <Border CornerRadius="20" Width="482" Height="64" BorderThickness="1" BorderBrush="White">
                    <PasswordBox BorderThickness="0"  HorizontalAlignment="Stretch"   VerticalAlignment="Stretch"  Background="{x:Null}" FontSize="48"/>

                </Border>
                <Border Width="482" Height="64" Margin="0,20" BorderThickness="1" BorderBrush="White" Background="#9D44FF" CornerRadius="20" >
                    <Button BorderThickness="0"  Content="Login" HorizontalAlignment="Stretch"   VerticalAlignment="Stretch" Background="Transparent" FontSize="31" FontFamily="Impact" FontWeight="Bold"   BorderBrush="{x:Null}" Foreground="White"/>

                </Border>
                <Border BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="400" Height="40" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="8,0" Text="Need register? Click here:" FontFamily="Impact" FontSize="16" Foreground="Black"/>
                        <Button  BorderThickness="0" Background="Transparent" Content="Register" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="183,0,0,0" Padding="8,4" FontFamily="Impact" FontSize="16" Foreground="White" Click="Button_Click"/>
                    </Grid>
                </Border>
            </StackPanel>


        </Border>

        <StackPanel HorizontalAlignment="Right">
            <Image HorizontalAlignment="Left" Height="688" Margin="820,70,0,0" VerticalAlignment="Top" Width="670" Source="/Graphics/MainGrap/Login/61967f80-ab26-4379-a087-ad1715df34f7.png"/>

        </StackPanel>




        </Grid>
    
</UserControl>
